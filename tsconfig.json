{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"paths": {
			"SERVER": ["./internal.d.ts"],
			"MANIFEST": ["./internal.d.ts"],
			"INLINED_ASSETS": ["./internal.d.ts"],
			"STATIC_PUBLISH_CONFIG": ["./internal.d.ts"]
		}
	},
	"include": ["**/*.js", "**/*.d.ts"],
	"exclude": ["node_modules"]
}
